     "nuid": "aaaead9b-0657-4ac9-963c-5a6041cc8384",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "df_region.select(\"Country\").distinct().display()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "f02e557d-8da4-4366-8f09-908c84183adc",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "#Replace United States with USA for standardization of Country column\n",
    "df_region = df_region.replace({\"United States\" : \"USA\"}, subset=[\"Country\"])\n",
    "display(df_region)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
