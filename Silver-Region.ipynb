   "source": [
    "#Display the contents of the Region.csv file\n",
    "display(spark.read.csv(\"/Volumes/workspace/default/accenture-final-project/bronze/Region.csv\", header=True, sep=\"\\t\"))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "14eabe8e-da3f-4b26-8ec0-aba1073bbfe3",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "#Define the Schema for Region \n",
    "from pyspark.sql.types import StructType, StructField, StringType, IntegerType\n",
    "\n",
    "region_schema = StructType([\n",
    "    StructField(\"SalesTerritoryKey\", IntegerType(),True),\n",
    "    StructField(\"Region\", StringType(), True),\n",
    "    StructField(\"Country\", StringType(), True),\n",
    "    StructField(\"Group\", StringType(), True)\n",
    "])\n",
    "\n",
    "#Create DataFrame for Region using predefined schema\n",
    "df_region = spark.read.csv(\"/Volumes/workspace/default/accenture-final-project/bronze/Region.csv\",  header=True, sep=\"\\t\", schema=region_schema)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "1ab01839-bf45-4f3d-b5be-4c1fa49e916a",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "#Rename Column SalesTerritoryKey to Sales_Territory_Key\n",
    "from pyspark.sql import functions as F\n",
    "\n",
    "df_region = df_region.withColumnRenamed(\"SalesTerritoryKey\", \"Sales_Territory_Key\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "e53d5867-bc18-46de-b798-eaafe6cd6ab8",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "#Trim Spaces\n",
    "df_region = df_region.select(\n",
    "    *(F.trim(F.col(c)).alias(c) \n",
    "      if isinstance(c, StringType) #if column is StringType then trim spaces, else keep it unchanged\n",
    "      else F.col(c) for c in df_region.columns)\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "979ce399-f585-4ddd-83ec-bb7995b70e54",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "#Check for duplicates\n",
    "duplicates = df_region.groupBy(df_region.columns).count().filter(F.col(\"count\") > 1)\n",
    "display(duplicates)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "cc944c11-7d2f-4841-bcbc-355620b3a0c8",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "#Check for missing values\n",
    "missing_values = df_region.select([F.count(F.when(F.col(c).isNull(), c)).alias(c) for c in df_region.columns])\n",

    "display(missing_values)\n"

    "display(missing_values)"

   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
