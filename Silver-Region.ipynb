    }
   },
   "outputs": [],
   "source": [
    "#Save Region DataFrame as Delta Table\n",

    "df_region.write.mode(\"overwrite\").format(\"delta\").saveAsTable(\"accenture_final_project.region_silver\")\n"

   ]
  }
